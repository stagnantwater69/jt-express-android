<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jtexpress.app">

    <!-- Internet for Firebase + Gemini API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for the floating AI bubble (draw over other apps) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Required for FloatingChatService to run as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Camera and storage for rider photo capture -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JTExpress">

        <!-- ════════════════════════════════════════
             SPLASH SCREEN
        ════════════════════════════════════════ -->
        <activity
            android:name=".shared.SplashActivity"
            android:theme="@style/Theme.JTExpress.Splash"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════
             ROLE ROUTER
             (reads Firestore role and redirects to correct dashboard)
        ════════════════════════════════════════ -->
        <activity
            android:name=".RoleRouterActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             AUTH SCREENS
        ════════════════════════════════════════ -->
        <activity
            android:name=".shared.LoginActivity"
            android:theme="@style/Theme.JTExpress.Login"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".shared.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".shared.ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".shared.EmailVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ════════════════════════════════════════
             CUSTOMER DASHBOARD
        ════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             RIDER DASHBOARD
        ════════════════════════════════════════ -->
        <activity
            android:name=".RiderMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             STAFF DASHBOARD
        ════════════════════════════════════════ -->
        <activity
            android:name=".StaffMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             ADMIN DASHBOARD
        ════════════════════════════════════════ -->
        <activity
            android:name=".AdminMainActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             AI CHATBOT SCREEN
             (shared — accessible by all roles)
        ════════════════════════════════════════ -->
        <activity
            android:name=".AiChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ════════════════════════════════════════
             FLOATING BUBBLE PERMISSION HANDLER
        ════════════════════════════════════════ -->
        <activity
            android:name=".OverlayPermissionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Translucent"/>

        <!-- ════════════════════════════════════════
             FLOATING BUBBLE SERVICE
             (draws the draggable AI bubble over all screens)
        ════════════════════════════════════════ -->
        <service
            android:name=".FloatingChatService"
            android:enabled="true"
            android:exported="false"/>

    </application>

</manifest>
