<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.jtexpress.app">

    <!-- Internet for Firebase + Gemini API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for the floating AI bubble (draw over other apps) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Required for FloatingChatService to run as a foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.JTExpress">

        <!-- ════════════════════════════════════════
             SPLASH SCREEN
        ════════════════════════════════════════ -->
        <activity
            android:name=".SplashActivity"
            android:theme="@style/Theme.JTExpress.Splash"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════
             AUTH SCREENS
        ════════════════════════════════════════ -->
        <activity
            android:name=".LoginActivity"
            android:theme="@style/Theme.JTExpress.Login"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".EmailVerificationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ════════════════════════════════════════
             MAIN DASHBOARD
        ════════════════════════════════════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════════════════════════════════════
             AI CHATBOT SCREEN
        ════════════════════════════════════════ -->
        <activity
            android:name=".AiChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ════════════════════════════════════════
             FLOATING BUBBLE PERMISSION HANDLER
        ════════════════════════════════════════ -->
        <activity
            android:name=".OverlayPermissionActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.Translucent"/>

        <!-- ════════════════════════════════════════
             FLOATING BUBBLE SERVICE
             (draws the draggable AI bubble over all screens)
        ════════════════════════════════════════ -->
        <service
            android:name=".FloatingChatService"
            android:enabled="true"
            android:exported="false"/>

    </application>

</manifest>