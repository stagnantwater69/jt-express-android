<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jt_white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_red_light_bg"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/jt_red"
            android:contentDescription="Back"
            android:layout_marginTop="24dp"/>

        <!-- Email envelope icon -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:background="@drawable/circle_red_light_bg">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_dialog_email"
                android:tint="@color/jt_red"
                android:contentDescription="Email"/>
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verify Your Email"
            android:textColor="@color/jt_black"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="24dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We sent a verification link to:"
            android:textColor="@color/jt_gray"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

        <!-- Email address display -->
        <TextView
            android:id="@+id/tv_email_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="user@email.com"
            android:textColor="@color/jt_red"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

        <!-- Instruction card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF5F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_red_light_bg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="1"
                            android:textColor="@color/jt_red"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Open your email inbox"
                        android:textColor="@color/jt_black"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <FrameLayout
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_red_light_bg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="2"
                            android:textColor="@color/jt_red"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Find the email from J&amp;T Express"
                        android:textColor="@color/jt_black"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/circle_red_light_bg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="3"
                            android:textColor="@color/jt_red"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Click the verification link in the email"
                        android:textColor="@color/jt_black"
                        android:textSize="13sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Check spam note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="14dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_dialog_info"
                android:tint="@color/jt_gray"
                android:contentDescription="Info"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Can't find it? Check your spam folder"
                android:textColor="@color/jt_gray"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- I've Verified button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_verified"
            style="@style/JT.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="I'VE VERIFIED MY EMAIL"
            android:textSize="14sp"
            android:layout_marginTop="32dp"
            app:cornerRadius="26dp"/>

        <!-- Resend button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resend"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="RESEND EMAIL"
            android:textColor="@color/jt_red"
            android:textSize="14sp"
            android:layout_marginTop="12dp"
            app:strokeColor="@color/jt_red"
            app:cornerRadius="26dp"/>

        <!-- Countdown timer -->
        <TextView
            android:id="@+id/tv_resend_timer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/jt_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

        <!-- Back to Login -->
        <TextView
            android:id="@+id/tv_back_to_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back to Login"
            android:textColor="@color/jt_red"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:paddingBottom="16dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>