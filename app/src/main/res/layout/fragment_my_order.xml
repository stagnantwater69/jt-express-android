<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/jt_white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Orders"
            android:textColor="@color/jt_black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"/>

        <!-- Search + Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_search"
                style="@style/JT.InputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Search tracking number..."
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/jt_gray">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapCharacters"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"/>
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textAllCaps="true"
                android:background="@drawable/bg_btn_red"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- Tabs with counts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout android:id="@+id/tab_all"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:paddingTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/count_all"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="6" android:textColor="@color/jt_red"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="All" android:textColor="@color/jt_red"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <View android:id="@+id/indicator_all"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:background="@color/jt_red"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tab_send"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:paddingTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/count_send"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="2" android:textColor="@color/jt_gray"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Send" android:textColor="@color/jt_gray"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <View android:id="@+id/indicator_send"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tab_receive"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:paddingTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/count_receive"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="3" android:textColor="@color/jt_gray"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Receive" android:textColor="@color/jt_gray"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <View android:id="@+id/indicator_receive"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tab_pending"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:paddingTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:id="@+id/count_pending"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1" android:textColor="@color/jt_gray"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pending" android:textColor="@color/jt_gray"
                    android:textSize="12sp" android:layout_marginBottom="8dp"/>
                <View android:id="@+id/indicator_pending"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/jt_divider"/>
    </LinearLayout>

    <!-- ===== ORDER LIST ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ORDER 1 — In Transit -->
            <androidx.cardview.widget.CardView
                android:id="@+id/order_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <!-- Row 1: badge + date -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SEND"
                            android:textColor="#B71C1C"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@drawable/badge_status_transit"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mar 11, 2026" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Row 2: tracking no + status -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="JT2024001234PH"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="In Transit" android:textColor="@color/jt_red"
                            android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Row 3: route + eta -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Manila" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  →  " android:textColor="@color/jt_red" android:textSize="13sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cebu" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Est. Mar 14" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Progress bar -->
                    <ProgressBar style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent" android:layout_height="7dp"
                        android:progress="60" android:max="100"
                        android:progressDrawable="@drawable/progress_bar_red"
                        android:layout_marginBottom="12dp"/>

                    <!-- Buttons -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_track_1"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Track"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_red"
                            android:layout_marginEnd="8dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_copy_1"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Copy No."
                            android:textColor="@color/jt_red"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_outline_red"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ORDER 2 — Delivered -->
            <androidx.cardview.widget.CardView
                android:id="@+id/order_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="RECEIVE"
                            android:textColor="#1B5E20"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@drawable/badge_status_delivered"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mar 10, 2026" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="JT2024000891PH"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Delivered ✓" android:textColor="#2E7D32"
                            android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Quezon City" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  →  " android:textColor="#2E7D32" android:textSize="13sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mandaue City" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Delivered" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <ProgressBar style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent" android:layout_height="7dp"
                        android:progress="100" android:max="100"
                        android:progressDrawable="@drawable/progress_bar_green"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_track_2"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Track"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_red"
                            android:layout_marginEnd="8dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_copy_2"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Copy No."
                            android:textColor="@color/jt_red"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_outline_red"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ORDER 3 — Pending -->
            <androidx.cardview.widget.CardView
                android:id="@+id/order_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SEND"
                            android:textColor="#BF360C"
                            android:textSize="10sp" android:textStyle="bold"
                            android:background="@drawable/badge_status_pending"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mar 12, 2026" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="JT2024001456PH"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pending Pickup" android:textColor="#E65100"
                            android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pasig City" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  →  " android:textColor="#E65100" android:textSize="13sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Davao City" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Awaiting" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                    </LinearLayout>

                    <ProgressBar style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent" android:layout_height="7dp"
                        android:progress="10" android:max="100"
                        android:progressDrawable="@drawable/progress_bar_orange"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_track_3"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Track"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_red"
                            android:layout_marginEnd="8dp"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_copy_3"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="Copy No."
                            android:textColor="@color/jt_red"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_outline_red"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>