<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/jt_white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Shipping Rates"
            android:textColor="@color/jt_black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"/>

        <!-- Domestic / International tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tab_domestic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="0dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Domestic"
                    android:textColor="@color/jt_red"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="10dp"/>
                <View
                    android:id="@+id/indicator_domestic"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@color/jt_red"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tab_international"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="4dp"
                android:paddingBottom="0dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="International"
                    android:textColor="@color/jt_gray"
                    android:textSize="14sp"
                    android:paddingBottom="10dp"/>
                <View
                    android:id="@+id/indicator_international"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@android:color/transparent"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/jt_divider"/>
    </LinearLayout>

    <!-- ===== SCROLLABLE FORM ===== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- FROM / TO CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- FROM -->
                    <LinearLayout
                        android:id="@+id/row_from"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle_red_light_bg">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_upload"
                                app:tint="@color/jt_red"
                                android:contentDescription="From"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FROM"
                                android:textColor="@color/jt_gray"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/tv_from_city"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select origin city"
                                android:textColor="@color/jt_gray"
                                android:textSize="14sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@color/jt_gray"
                            android:contentDescription="Select"/>
                    </LinearLayout>

                    <!-- Connector line -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="19dp"
                        android:background="@color/jt_divider"/>

                    <!-- TO -->
                    <LinearLayout
                        android:id="@+id/row_to"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/circle_orange_light_bg">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="#E65100"
                                android:contentDescription="To"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TO"
                                android:textColor="@color/jt_gray"
                                android:textSize="10sp"
                                android:letterSpacing="0.1"/>
                            <TextView
                                android:id="@+id/tv_to_city"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select destination city"
                                android:textColor="@color/jt_gray"
                                android:textSize="14sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@color/jt_gray"
                            android:contentDescription="Select"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ITEM DETAILS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Item Details"
                        android:textColor="@color/jt_red"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp"/>

                    <!-- Service Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Type"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:id="@+id/service_super"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_selected_bg"
                            android:layout_marginEnd="6dp"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_service_super"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="J&amp;T Super" android:textColor="@color/jt_red"
                                android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/service_express"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_unselected_bg"
                            android:layout_marginEnd="6dp"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_service_express"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="J&amp;T Express" android:textColor="@color/jt_gray"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/service_economy"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_unselected_bg"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_service_economy"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Economy" android:textColor="@color/jt_gray"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Weight -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weight (KG)"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- FIX: outline circle minus button -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_weight_minus"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="−"
                            android:textSize="20sp"
                            android:textColor="@color/jt_red"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_circle_outline"
                            android:padding="0dp"/>

                        <TextView
                            android:id="@+id/tv_weight"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1"
                            android:textColor="@color/jt_black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                        <!-- FIX: solid circle plus button -->
                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_weight_plus"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="+"
                            android:textSize="20sp"
                            android:textColor="#FFFFFF"
                            android:textAllCaps="false"
                            android:background="@drawable/bg_btn_red_rounded"
                            android:padding="0dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" KG"
                            android:textColor="@color/jt_gray"
                            android:textSize="14sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <!-- Goods Category -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goods Category"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:id="@+id/cat_parcel"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_selected_bg"
                            android:layout_marginEnd="6dp"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_cat_parcel"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Parcel" android:textColor="@color/jt_red"
                                android:textSize="13sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/cat_document"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_unselected_bg"
                            android:layout_marginEnd="6dp"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_cat_document"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Document" android:textColor="@color/jt_gray"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout android:id="@+id/cat_fragile"
                            android:layout_width="0dp" android:layout_height="40dp"
                            android:layout_weight="1" android:gravity="center"
                            android:background="@drawable/service_unselected_bg"
                            android:clickable="true" android:focusable="true">
                            <TextView android:id="@+id/tv_cat_fragile"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Fragile" android:textColor="@color/jt_gray"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- DIMENSION CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Dimensions (cm)"
                            android:textColor="@color/jt_red"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dimensional Weight: "
                            android:textColor="@color/jt_gray"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_dim_weight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 KG"
                            android:textColor="@color/jt_red"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_length"
                            style="@style/JT.InputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Length"
                            android:layout_marginEnd="4dp"
                            app:suffixText="cm">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_length"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textSize="14sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="×" android:textColor="@color/jt_gray"
                            android:textSize="16sp" android:layout_marginEnd="4dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_width"
                            style="@style/JT.InputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Width"
                            android:layout_marginEnd="4dp"
                            app:suffixText="cm">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_width"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textSize="14sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="×" android:textColor="@color/jt_gray"
                            android:textSize="16sp" android:layout_marginEnd="4dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_height"
                            style="@style/JT.InputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Height"
                            app:suffixText="cm">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_height"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textSize="14sp"/>
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="L × W × H must not exceed 180cm each"
                        android:textColor="@color/jt_gray"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- RESULT CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/jt_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estimated Rate"
                        android:textColor="@color/jt_red"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Shipping Fee" android:textColor="@color/jt_gray"
                                android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_shipping_fee"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="₱ --" android:textColor="@color/jt_black"
                                android:textSize="24sp" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Est. Delivery" android:textColor="@color/jt_gray"
                                android:textSize="12sp"/>
                            <TextView android:id="@+id/tv_est_delivery"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="2-3 days" android:textColor="@color/jt_red"
                                android:textSize="16sp" android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/jt_divider"
                        android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Chargeable Weight"
                            android:textColor="@color/jt_gray" android:textSize="12sp"/>
                        <TextView android:id="@+id/tv_chargeable_weight"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1 KG" android:textColor="@color/jt_black"
                            android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== CHECK RATE BUTTON — FIX: AppCompatButton with explicit white text ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/jt_white"
        android:padding="16dp"
        android:elevation="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_check_rate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="CHECK RATE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_red_rounded"/>

    </LinearLayout>

</LinearLayout>