<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/jt_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Red Header Background -->
        <View
            android:id="@+id/header_bg"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/jt_red"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Decorative circles -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.12"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-40dp"/>

        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="130dp"
            android:layout_marginStart="-30dp"/>

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/jt_white"
            android:contentDescription="Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="44dp"
            android:layout_marginStart="16dp"/>

        <!-- Header Logo -->
        <LinearLayout
            android:id="@+id/header_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="44dp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_bg">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="J&amp;T"
                    android:textColor="@color/jt_red"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J&amp;T Express"
                android:textColor="@color/jt_white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Header Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="@color/jt_white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/header_logo"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We'll send a reset link to your email"
            android:textColor="@color/jt_white"
            android:textSize="12sp"
            android:alpha="0.85"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"/>

        <!-- ══════════════════════════════════════
             STEP INDICATOR — 2 steps only
        ══════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="16dp"
            android:translationZ="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="10dp">

            <!-- Step 1 dot — active by default -->
            <TextView
                android:id="@+id/step1_dot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="1"
                android:textColor="@color/jt_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_white_bg"/>

            <!-- Connector line -->
            <View
                android:layout_width="24dp"
                android:layout_height="2dp"
                android:background="@color/jt_white"
                android:alpha="0.5"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <!-- Step 2 dot — inactive by default -->
            <TextView
                android:id="@+id/step2_dot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="2"
                android:textColor="@color/jt_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_outline_white"
                android:alpha="0.5"/>

            <!--
                Step 3 dot REMOVED — Firebase handles password reset
                via email link, so there is no Step 3 in the app.
            -->

        </LinearLayout>

        <!-- ══════════════════════════════════════
             STEP 1 — Enter Email
        ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Lock icon -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_red_light_bg">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="Lock"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/jt_red"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:text="Enter your registered email address and we will send you a password reset link."
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"/>

                <!-- Email input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/JT.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="Email Address"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/jt_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/jt_black"
                        android:textSize="15sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Send button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_code"
                    style="@style/JT.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="SEND RESET LINK"/>

                <!-- Back to Login -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_login"
                    style="@style/JT.Button.Google"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Back to Login"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════
             STEP 2 — Link Sent Confirmation
             (final step — reset happens in email)
        ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Email icon -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/circle_red_light_bg"
                    android:layout_gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="@color/jt_red"
                        android:contentDescription="Email sent"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Check your email!"
                    android:textColor="@color/jt_black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="14dp"/>

                <!-- Dynamic email + instructions text -->
                <TextView
                    android:id="@+id/tv_email_sent_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="We sent a password reset link to your email."
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:lineSpacingMultiplier="1.6"/>

                <!-- Expiry timer notice -->
                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏱ The link expires in 10 minutes."
                    android:textColor="@color/jt_red"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>

                <!-- Open Email App button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_verify_code"
                    style="@style/JT.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OPEN EMAIL APP"
                    android:layout_marginTop="20dp"/>

                <!-- Resend -->
                <TextView
                    android:id="@+id/tv_resend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Didn't receive it? Resend"
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="14dp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/jt_divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Helpful note -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 After resetting your password in your email, come back and log in with your new password."
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--
            card_step3 is kept in XML with visibility=gone so the
            existing Kotlin code that hides it doesn't crash.
            It will never be shown to the user.
        -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="gone"/>

        <!-- Bottom hint -->
        <TextView
            android:id="@+id/tv_bottom_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remembered your password? Log In"
            android:textColor="@color/jt_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/card_step1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>