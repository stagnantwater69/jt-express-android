<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/jt_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Red Header Background -->
        <View
            android:id="@+id/header_bg"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@color/jt_red"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Decorative circles -->
        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.12"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-50dp"
            android:layout_marginEnd="-40dp"/>

        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.10"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="130dp"
            android:layout_marginStart="-30dp"/>

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/jt_white"
            android:contentDescription="Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="44dp"
            android:layout_marginStart="16dp"/>

        <!-- Header Logo -->
        <LinearLayout
            android:id="@+id/header_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="44dp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_bg">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="J&amp;T"
                    android:textColor="@color/jt_red"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="J&amp;T Express"
                android:textColor="@color/jt_white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Header Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="@color/jt_white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/header_logo"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We'll send a verification code to your email"
            android:textColor="@color/jt_white"
            android:textSize="12sp"
            android:alpha="0.85"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"/>

        <!-- Step Indicator -->
        <LinearLayout
            android:id="@+id/step_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="16dp"
            android:translationZ="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/step1_dot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="1"
                android:textColor="@color/jt_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_white_bg"/>

            <View android:layout_width="24dp" android:layout_height="2dp"
                android:background="@color/jt_white" android:alpha="0.5"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/step2_dot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="2"
                android:textColor="@color/jt_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_outline_white"
                android:alpha="0.5"/>

            <View android:layout_width="24dp" android:layout_height="2dp"
                android:background="@color/jt_white" android:alpha="0.5"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/step3_dot"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="3"
                android:textColor="@color/jt_white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/circle_outline_white"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- ===== STEP 1: Enter Email ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_red_light_bg">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="Lock"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/jt_red" />
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5"
                    android:text="Enter your registered email address and we will send you a 6-digit verification code."
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/JT.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="Email Address"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/jt_gray">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/jt_black"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_code"
                    style="@style/JT.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="SEND VERIFICATION CODE" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_login"
                    style="@style/JT.Button.Google"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Back to Login" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== STEP 2: Enter OTP ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/circle_red_light_bg"
                    android:layout_gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="@color/jt_red"
                        android:contentDescription="Email sent"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Check your email!"
                    android:textColor="@color/jt_black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:id="@+id/tv_email_sent_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="We sent a 6-digit code to\nyour@email.com"
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.5"/>

                <!-- 6 OTP Boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="24dp">

                    <EditText
                        android:id="@+id/et_otp1"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/et_otp2"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/et_otp3"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/et_otp4"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/et_otp5"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/et_otp6"
                        android:layout_width="46dp"
                        android:layout_height="54dp"
                        android:background="@drawable/otp_box_bg"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/jt_black"/>
                </LinearLayout>

                <!-- Countdown Timer -->
                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Code expires in: 05:00"
                    android:textColor="@color/jt_red"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:id="@+id/tv_resend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Didn't receive a code? Resend"
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_verify_code"
                    style="@style/JT.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VERIFY CODE"
                    android:layout_marginTop="20dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== STEP 3: New Password ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_step3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white"
            app:layout_constraintTop_toTopOf="@id/header_bg"
            android:layout_marginTop="170dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/circle_red_light_bg"
                    android:layout_gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_lock_lock"
                        app:tint="@color/jt_red"
                        android:contentDescription="New password"/>
                </FrameLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create New Password"
                    android:textColor="@color/jt_black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="14dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your new password must be at least 8 characters and different from your previous one."
                    android:textColor="@color/jt_gray"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.5"/>

                <!-- Password Strength -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password Strength"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginTop="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <View android:id="@+id/strength_bar1" android:layout_width="0dp"
                        android:layout_height="6dp" android:layout_weight="1"
                        android:background="@drawable/strength_bar_inactive" android:layout_marginEnd="4dp"/>
                    <View android:id="@+id/strength_bar2" android:layout_width="0dp"
                        android:layout_height="6dp" android:layout_weight="1"
                        android:background="@drawable/strength_bar_inactive" android:layout_marginEnd="4dp"/>
                    <View android:id="@+id/strength_bar3" android:layout_width="0dp"
                        android:layout_height="6dp" android:layout_weight="1"
                        android:background="@drawable/strength_bar_inactive" android:layout_marginEnd="4dp"/>
                    <View android:id="@+id/strength_bar4" android:layout_width="0dp"
                        android:layout_height="6dp" android:layout_weight="1"
                        android:background="@drawable/strength_bar_inactive"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_strength_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>

                <!-- New Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_new_password"
                    style="@style/JT.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="New Password"
                    android:layout_marginTop="12dp"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/jt_gray"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/jt_red">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_new_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:textSize="15sp"
                        android:textColor="@color/jt_black"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Requirements -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="4dp">

                    <TextView android:id="@+id/req_length"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✗  At least 8 characters"
                        android:textColor="@color/jt_gray" android:textSize="12sp"/>

                    <TextView android:id="@+id/req_uppercase"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✗  At least one uppercase letter"
                        android:textColor="@color/jt_gray" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>

                    <TextView android:id="@+id/req_number"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✗  At least one number"
                        android:textColor="@color/jt_gray" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Confirm New Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_confirm_password"
                    style="@style/JT.InputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Confirm New Password"
                    android:layout_marginTop="14dp"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="@color/jt_gray"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/jt_red">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textSize="15sp"
                        android:textColor="@color/jt_black"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password match indicator -->
                <TextView
                    android:id="@+id/tv_password_match"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_password"
                    style="@style/JT.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RESET PASSWORD"
                    android:layout_marginTop="20dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom hint -->
        <TextView
            android:id="@+id/tv_bottom_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remembered your password? Log In"
            android:textColor="@color/jt_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toBottomOf="@id/card_step1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>