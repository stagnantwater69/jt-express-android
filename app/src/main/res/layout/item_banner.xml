<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/jt_red">

        <!-- Decorative circles -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.15"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="-40dp"/>

        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_light_overlay"
            android:alpha="0.10"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="-20dp"
            android:layout_marginBottom="-20dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true"
            android:layout_marginStart="20dp">

            <!-- DYNAMIC: banner title -->
            <TextView
                android:id="@+id/tv_banner_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/jt_white"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <!-- DYNAMIC: banner subtitle -->
            <TextView
                android:id="@+id/tv_banner_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/jt_yellow"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <!-- DYNAMIC: banner body -->
            <TextView
                android:id="@+id/tv_banner_body"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/jt_white"
                android:textSize="11sp"
                android:alpha="0.9"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.4"/>

            <!-- DYNAMIC: banner tag/promo line -->
            <TextView
                android:id="@+id/tv_banner_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/jt_yellow"
                android:textSize="10sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>