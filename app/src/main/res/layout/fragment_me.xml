<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== RED PROFILE HEADER ===== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/jt_red"
            android:paddingBottom="52dp">

            <!-- Decorative circle top-right -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/circle_light_overlay"
                android:alpha="0.12"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="-50dp"
                android:layout_marginEnd="-50dp"/>

            <!-- Decorative circle bottom-left -->
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/circle_light_overlay"
                android:alpha="0.09"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="-25dp"
                android:layout_marginBottom="-15dp"/>

            <!-- Settings icon — top right -->
            <FrameLayout
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_white_30"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="@color/jt_white"
                    android:contentDescription="Settings"/>
            </FrameLayout>

            <!-- Avatar + Name + Email row -->
            <LinearLayout
                android:id="@+id/profile_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="68dp"
                android:paddingTop="52dp"
                android:paddingBottom="16dp">

                <!-- Avatar with edit badge -->
                <FrameLayout
                    android:id="@+id/btn_edit_avatar"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- White circle background -->
                    <FrameLayout
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@drawable/circle_white_bg">
                        <TextView
                            android:id="@+id/tv_avatar_large"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="JD"
                            android:textColor="@color/jt_red"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </FrameLayout>

                    <!-- Edit badge bottom-right -->
                    <FrameLayout
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/circle_white_bg"
                        android:elevation="2dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/jt_red"
                            android:contentDescription="Edit photo"/>
                    </FrameLayout>
                </FrameLayout>

                <!-- Name / email / badge column -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juan Dela Cruz"
                        android:textColor="@color/jt_white"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="juan@email.com"
                        android:textColor="@color/jt_white"
                        android:alpha="0.85"
                        android:textSize="13sp"
                        android:layout_marginTop="3dp"/>

                    <!-- Member badge pill -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="26dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_badge_white_30"
                        android:paddingStart="10dp"
                        android:paddingEnd="12dp"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/star_on"
                            app:tint="@color/jt_yellow"
                            android:contentDescription="Member star"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Member"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <!-- ===== STATS CARD (overlaps header) ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-34dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal">

                <!-- Carrots -->
                <LinearLayout
                    android:id="@+id/btn_carrots"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥕"
                        android:textSize="20sp"/>
                    <TextView
                        android:id="@+id/tv_carrots"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9"
                        android:textColor="@color/jt_black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="1dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Carrots ›"
                        android:textColor="@color/jt_gray"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/jt_divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Vouchers -->
                <LinearLayout
                    android:id="@+id/btn_vouchers"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎟️"
                        android:textSize="20sp"/>
                    <TextView
                        android:id="@+id/tv_vouchers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/jt_black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="1dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Vouchers ›"
                        android:textColor="@color/jt_gray"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/jt_divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Orders -->
                <LinearLayout
                    android:id="@+id/btn_my_orders_stat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦"
                        android:textSize="20sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6"
                        android:textColor="@color/jt_black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="1dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Orders ›"
                        android:textColor="@color/jt_gray"
                        android:textSize="10sp"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== ACCOUNT SECTION ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACCOUNT"
            android:textColor="@color/jt_gray"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Edit Profile -->
                <LinearLayout
                    android:id="@+id/menu_edit_profile"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="@color/jt_red"
                            android:contentDescription="Edit Profile"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Edit Profile"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- Address Book -->
                <LinearLayout
                    android:id="@+id/menu_address_book"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/jt_red"
                            android:contentDescription="Address Book"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Address Book"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- Change Password -->
                <LinearLayout
                    android:id="@+id/menu_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/jt_red"
                            android:contentDescription="Change Password"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Change Password"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== SUPPORT SECTION ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SUPPORT"
            android:textColor="@color/jt_gray"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Contact Us -->
                <LinearLayout
                    android:id="@+id/menu_contact"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/jt_red"
                            android:contentDescription="Contact Us"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Contact Us"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- FAQ -->
                <LinearLayout
                    android:id="@+id/menu_faq"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_help"
                            app:tint="@color/jt_red"
                            android:contentDescription="FAQ"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FAQ"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- Rate the App -->
                <LinearLayout
                    android:id="@+id/menu_rate_app"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/star_on"
                            app:tint="@color/jt_red"
                            android:contentDescription="Rate the App"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rate the App"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== GENERAL SECTION ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GENERAL"
            android:textColor="@color/jt_gray"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="6dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Terms & Conditions -->
                <LinearLayout
                    android:id="@+id/menu_terms"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/jt_red"
                            android:contentDescription="Terms"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Terms &amp; Conditions"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/menu_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/jt_red"
                            android:contentDescription="Privacy"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Privacy &amp; Policy"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider" android:layout_marginStart="66dp"/>

                <!-- Clear Cache -->
                <LinearLayout
                    android:id="@+id/menu_clear_cache"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_delete"
                            app:tint="@color/jt_red"
                            android:contentDescription="Clear Cache"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Clear Cache"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:layout_marginStart="14dp"/>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_media_next"
                        app:tint="#BBBBBB"
                        android:contentDescription="Go"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== LOGOUT BUTTON ===== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
