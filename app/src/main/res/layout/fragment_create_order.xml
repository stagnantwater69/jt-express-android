<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ===== TOP BAR ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="44dp"
            android:paddingBottom="12dp"
            android:background="@color/jt_white">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/jt_black"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order"
                android:textColor="@color/jt_black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <View
                android:layout_width="40dp"
                android:layout_height="40dp"/>
        </LinearLayout>

        <!-- ===== SENDER / RECIPIENT CARD ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Sender Row -->
                <LinearLayout
                    android:id="@+id/ll_sender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_upload"
                            app:tint="@color/jt_red"
                            android:contentDescription="Sender"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sender"
                            android:textColor="@color/jt_black"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_sender_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap here to fill up sender information"
                            android:textColor="@color/jt_gray"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/jt_gray"
                        android:contentDescription="Edit Sender"/>
                </LinearLayout>

                <!-- Dotted divider (arrow) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp">

                    <FrameLayout
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_send"
                            app:tint="@color/jt_gray"
                            android:contentDescription="Arrow down"/>
                    </FrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/jt_divider"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Recipient Row -->
                <LinearLayout
                    android:id="@+id/ll_recipient"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/circle_red_light_bg">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#FF9800"
                            android:contentDescription="Recipient"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Recipient"
                            android:textColor="@color/jt_black"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_recipient_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap here to fill up receiver information"
                            android:textColor="@color/jt_gray"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/jt_gray"
                        android:contentDescription="Edit Recipient"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== DROP-OFF / PICKUP TAB ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Tab buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@drawable/tab_bg_gray"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tab_dropoff"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Drop Off"
                        android:textColor="@color/jt_red"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/tab_selected_bg"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tab_pickup"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="PICKUP"
                        android:textColor="@color/jt_gray"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Drop-off branch selection -->
                <LinearLayout
                    android:id="@+id/ll_dropoff_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:id="@+id/ll_select_branch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_border_bg"
                        android:padding="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <FrameLayout
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/circle_red_light_bg">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_mapmode"
                                app:tint="@color/jt_red"
                                android:contentDescription="Branch"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tv_branch_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select a drop-off branch"
                                android:textColor="@color/jt_black"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tv_branch_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/jt_gray"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_branch_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/jt_gray"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Pickup schedule content -->
                <LinearLayout
                    android:id="@+id/ll_pickup_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <!-- Pickup Date -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pickup Date"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:id="@+id/ll_pickup_date"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/rounded_border_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_today"
                            app:tint="@color/jt_red"
                            android:contentDescription="Calendar"/>

                        <TextView
                            android:id="@+id/tv_pickup_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Select date"
                            android:textColor="@color/jt_gray"
                            android:textSize="13sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <!-- Pickup Time Slot -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time Slot"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btn_slot_morning"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="9AM–12PM"
                            android:textSize="12sp"
                            android:textColor="@color/jt_gray"
                            android:gravity="center"
                            android:background="@drawable/rounded_border_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:id="@+id/btn_slot_afternoon"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:text="1PM–5PM"
                            android:textSize="12sp"
                            android:textColor="@color/jt_gray"
                            android:gravity="center"
                            android:background="@drawable/rounded_border_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== EXPRESS TYPE ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Express Type &amp; Estimated time of Delivery"
                    android:textColor="@color/jt_red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Loading state -->
                <ProgressBar
                    android:id="@+id/progress_parcel_types"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="visible"/>

                <LinearLayout
                    android:id="@+id/ll_parcel_types"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== ITEM DESCRIPTION ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item(s) Description"
                    android:textColor="@color/jt_red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Item Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item Name"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_item_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. Clothes, Electronics..."
                    android:textSize="13sp"
                    android:background="@drawable/rounded_border_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:layout_marginBottom="12dp"/>

                <!-- Item Category -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:id="@+id/ll_category_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/rounded_border_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_category"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Select category"
                        android:textColor="@color/jt_gray"
                        android:textSize="13sp"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/jt_gray"
                        android:contentDescription="Dropdown"/>
                </LinearLayout>

                <!-- Row: Quantity + Weight -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quantity"
                            android:textColor="@color/jt_gray"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_quantity"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:hint="1"
                            android:textSize="13sp"
                            android:background="@drawable/rounded_border_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:inputType="number"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weight (KG)"
                            android:textColor="@color/jt_gray"
                            android:textSize="12sp"
                            android:layout_marginBottom="4dp"/>

                        <EditText
                            android:id="@+id/et_weight"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:hint="0.00"
                            android:textSize="13sp"
                            android:background="@drawable/rounded_border_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Goods Value -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goods Value (PHP)"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/et_goods_value"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="0.00"
                    android:textSize="13sp"
                    android:background="@drawable/rounded_border_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp"/>

                <!-- Optional Dimensions Toggle -->
                <LinearLayout
                    android:id="@+id/ll_toggle_dimensions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add dimensions (optional)"
                        android:textColor="@color/jt_red"
                        android:textSize="12sp"/>

                    <ImageView
                        android:id="@+id/iv_dimensions_arrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/jt_red"
                        android:contentDescription="Toggle"/>
                </LinearLayout>

                <!-- Dimensions (hidden by default) -->
                <LinearLayout
                    android:id="@+id/ll_dimensions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Length (cm)" android:textColor="@color/jt_gray" android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>
                        <EditText
                            android:id="@+id/et_length"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:hint="0.00" android:textSize="12sp"
                            android:background="@drawable/rounded_border_bg"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Width (cm)" android:textColor="@color/jt_gray" android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>
                        <EditText
                            android:id="@+id/et_width"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:hint="0.00" android:textSize="12sp"
                            android:background="@drawable/rounded_border_bg"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Height (cm)" android:textColor="@color/jt_gray" android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>
                        <EditText
                            android:id="@+id/et_height"
                            android:layout_width="match_parent" android:layout_height="44dp"
                            android:hint="0.00" android:textSize="12sp"
                            android:background="@drawable/rounded_border_bg"
                            android:paddingStart="10dp" android:paddingEnd="10dp"
                            android:inputType="numberDecimal"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Volume weight display -->
                <LinearLayout
                    android:id="@+id/ll_vol_weight_display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Volumetric Weight:"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_vol_weight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 KG"
                        android:textColor="@color/jt_black"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_chargeable_display"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chargeable Weight:"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_chargeable_weight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00 KG"
                        android:textColor="@color/jt_red"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== EXCLUSIVE DISCOUNT ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:id="@+id/ll_exclusive_discount"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Exclusive discount"
                    android:textColor="@color/jt_red"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_exclusive_discount_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please select"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/jt_gray"
                    android:layout_marginStart="4dp"
                    android:contentDescription="Arrow"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== VOUCHERS ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vouchers"
                    android:textColor="@color/jt_red"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/rounded_border_bg">

                    <EditText
                        android:id="@+id/et_voucher_code"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Enter voucher code"
                        android:textSize="13sp"
                        android:background="@null"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:inputType="textCapCharacters"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_apply_voucher"
                        style="@style/JT.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Apply"
                        android:layout_marginEnd="8dp"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_voucher_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== COST SUMMARY ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cost Summary"
                    android:textColor="@color/jt_black"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Shipment Fee -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Shipment Fee"
                        android:textColor="@color/jt_gray" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_cost_shipment"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHP 0.00" android:textColor="@color/jt_black" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Service Fee -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Service Fee"
                        android:textColor="@color/jt_gray" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_cost_service"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHP 0.00" android:textColor="@color/jt_black" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Valuation Fee -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Valuation Fee"
                        android:textColor="@color/jt_gray" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_cost_valuation"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHP 0.00" android:textColor="@color/jt_black" android:textSize="12sp"/>
                </LinearLayout>

                <!-- Voucher Discount -->
                <LinearLayout android:id="@+id/ll_cost_voucher_row"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp"
                    android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Voucher Discount"
                        android:textColor="@color/jt_gray" android:textSize="12sp"/>
                    <TextView android:id="@+id/tv_cost_voucher_disc"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="- PHP 0.00" android:textColor="@android:color/holo_green_dark"
                        android:textSize="12sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider"
                    android:layout_marginTop="4dp" android:layout_marginBottom="8dp"/>

                <!-- Total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Estimate Cost"
                        android:textColor="@color/jt_black" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_cost_total"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PHP 0" android:textColor="@color/jt_red"
                        android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== TERMS ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="12dp">

            <CheckBox
                android:id="@+id/cb_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/jt_red"/>

            <TextView
                android:id="@+id/tv_terms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I have read, understand and agreed to the Terms and Conditions"
                android:textColor="@color/jt_gray"
                android:textSize="11sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- ===== SUBMIT BUTTON ===== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_order"
            style="@style/JT.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Submit"
            android:textSize="15sp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cornerRadius="26dp"/>

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/progress_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>