<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== DEFAULT LIST VIEW ===== -->
    <LinearLayout
        android:id="@+id/layout_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:visibility="visible">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/jt_white"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="44dp"
            android:paddingBottom="12dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Drop Points Nearby"
                android:textColor="@color/jt_black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/search_input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/jt_gray"
                    android:contentDescription="Search"/>

                <EditText
                    android:id="@+id/et_location_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search by area, barangay, city..."
                    android:textSize="13sp"
                    android:textColor="@color/jt_black"
                    android:textColorHint="@color/jt_gray"
                    android:paddingStart="10dp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"/>

                <ImageButton
                    android:id="@+id/btn_use_location"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/circle_red_light_bg"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="@color/jt_red"
                    android:contentDescription="Use my location"
                    android:padding="8dp"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chip_all"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="All" android:textSize="12sp"
                        android:textColor="@color/jt_white"
                        android:background="@drawable/chip_active_bg"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_drop"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="Drop Point" android:textSize="12sp"
                        android:textColor="@color/jt_gray"
                        android:background="@drawable/chip_inactive_bg"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_home"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="J&amp;T Home" android:textSize="12sp"
                        android:textColor="@color/jt_gray"
                        android:background="@drawable/chip_inactive_bg"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_store"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="J&amp;T Store" android:textSize="12sp"
                        android:textColor="@color/jt_gray"
                        android:background="@drawable/chip_inactive_bg"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_open"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="Open Now" android:textSize="12sp"
                        android:textColor="@color/jt_gray"
                        android:background="@drawable/chip_inactive_bg"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- Results count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="12dp" android:paddingBottom="4dp">

            <TextView android:id="@+id/tv_result_count"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3 drop points found near you"
                android:textColor="@color/jt_gray" android:textSize="12sp"/>

            <ImageView
                android:layout_width="18dp" android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/jt_gray" android:contentDescription="Sort"/>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text=" Nearest"
                android:textColor="@color/jt_gray" android:textSize="12sp"/>
        </LinearLayout>

        <!-- Drop point list -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="4dp" android:paddingBottom="8dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- BRANCH 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/branch_1"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/jt_white"
                    android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="J&amp;T Home" android:textColor="#B71C1C"
                                android:textSize="10sp" android:textStyle="bold"
                                android:background="@drawable/badge_status_transit"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  •  Open Now" android:textColor="#2E7D32" android:textSize="11sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="@color/jt_red" android:contentDescription="Distance"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" 1.28 KM" android:textColor="@color/jt_red"
                                android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="H-MANDAUE CITY-TABOK-01"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PH04000012" android:textColor="#B71C1C"
                                android:textSize="11sp" android:background="@drawable/badge_status_transit"
                                android:paddingStart="6dp" android:paddingEnd="6dp"
                                android:paddingTop="2dp" android:paddingBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  MANDAUE CITY" android:textColor="@color/jt_gray" android:textSize="12sp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/jt_divider"
                            android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/jt_gray" android:contentDescription="Address"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  Hi-way Tabok, Mandaue City"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="@color/jt_gray" android:contentDescription="Hours"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  9:30 AM – 6:00 PM  (Mon–Sat)"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="@color/jt_gray" android:contentDescription="Phone"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  9421872457"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginTop="12dp">
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_directions_1"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Directions" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_red"
                                android:layout_marginEnd="8dp"/>
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_call_1"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Call" android:textColor="@color/jt_red"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_outline_red"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BRANCH 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/branch_2"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/jt_white"
                    android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Drop Point" android:textColor="#BF360C"
                                android:textSize="10sp" android:textStyle="bold"
                                android:background="@drawable/badge_status_pending"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  •  Open Now" android:textColor="#2E7D32" android:textSize="11sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="@color/jt_red" android:contentDescription="Distance"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" 2.15 KM" android:textColor="@color/jt_red"
                                android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="H-MANDAUE CITY-CENTRO-03"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PH04000033" android:textColor="#BF360C"
                                android:textSize="11sp" android:background="@drawable/badge_status_pending"
                                android:paddingStart="6dp" android:paddingEnd="6dp"
                                android:paddingTop="2dp" android:paddingBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  MANDAUE CITY" android:textColor="@color/jt_gray" android:textSize="12sp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/jt_divider"
                            android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/jt_gray" android:contentDescription="Address"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  National Highway, Centro, Mandaue"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="@color/jt_gray" android:contentDescription="Hours"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  8:00 AM – 7:00 PM  (Mon–Sun)"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="@color/jt_gray" android:contentDescription="Phone"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  9321456789"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginTop="12dp">
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_directions_2"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Directions" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_red"
                                android:layout_marginEnd="8dp"/>
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_call_2"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Call" android:textColor="@color/jt_red"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_outline_red"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BRANCH 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/branch_3"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp" app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/jt_white"
                    android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="J&amp;T Store" android:textColor="#1B5E20"
                                android:textSize="10sp" android:textStyle="bold"
                                android:background="@drawable/badge_status_delivered"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  •  Closed" android:textColor="@color/jt_gray" android:textSize="11sp"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="@color/jt_red" android:contentDescription="Distance"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text=" 3.40 KM" android:textColor="@color/jt_red"
                                android:textSize="12sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="J&amp;T STORE - TIPOLO MANDAUE"
                            android:textColor="@color/jt_black" android:textSize="15sp" android:textStyle="bold"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="PH04000076" android:textColor="#1B5E20"
                                android:textSize="11sp" android:background="@drawable/badge_status_delivered"
                                android:paddingStart="6dp" android:paddingEnd="6dp"
                                android:paddingTop="2dp" android:paddingBottom="2dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="  MANDAUE CITY" android:textColor="@color/jt_gray" android:textSize="12sp"/>
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/jt_divider"
                            android:layout_marginTop="10dp" android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/jt_gray" android:contentDescription="Address"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  Tipolo, Mandaue City, Cebu"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="@color/jt_gray" android:contentDescription="Hours"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  9:00 AM – 5:00 PM  (Mon–Fri)"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_call"
                                app:tint="@color/jt_gray" android:contentDescription="Phone"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="  9187654321"
                                android:textColor="@color/jt_black" android:textSize="13sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginTop="12dp">
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_directions_3"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Directions" android:textColor="#FFFFFF"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_red"
                                android:layout_marginEnd="8dp"/>
                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_call_3"
                                android:layout_width="0dp" android:layout_height="40dp"
                                android:layout_weight="1"
                                android:text="Call" android:textColor="@color/jt_red"
                                android:textSize="13sp" android:textAllCaps="false"
                                android:background="@drawable/bg_btn_outline_red"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- ===== MAP VIEW (shown when location button tapped) ===== -->
    <FrameLayout
        android:id="@+id/layout_map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- WebView renders Google Maps embed — no SDK needed -->
        <WebView
            android:id="@+id/map_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/jt_white"
            android:paddingTop="44dp"
            android:paddingBottom="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:elevation="6dp">

            <ImageButton
                android:id="@+id/btn_back_to_list"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/jt_gray"
                android:contentDescription="Back"
                android:padding="6dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Drop Point Nearby"
                android:textColor="@color/jt_black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="8dp"/>
        </LinearLayout>

        <!-- Bottom sheet -->
        <androidx.cardview.widget.CardView
            android:id="@+id/map_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/jt_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Branch name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏠 "
                        android:textSize="16sp"/>
                    <TextView
                        android:id="@+id/map_branch_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="H-MANDAUE CITY-TABOK-01 J&amp;T Home"
                        android:textColor="@color/jt_black"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Code + city + distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:id="@+id/map_branch_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PH04000012"
                        android:textColor="#B71C1C"
                        android:textSize="11sp"
                        android:background="@drawable/badge_status_transit"
                        android:paddingStart="6dp" android:paddingEnd="6dp"
                        android:paddingTop="2dp" android:paddingBottom="2dp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="  MANDAUE-CITY"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/map_branch_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.28 KM"
                        android:textColor="@color/jt_gray"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/map_branch_hours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Operating Hours:  9:30–18:00  1,2,3,4,5,6"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/map_branch_function"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Function: Regular walk-in (parcel sending)"
                    android:textColor="@color/jt_gray"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/jt_divider"
                    android:layout_marginBottom="10dp"/>

                <!-- Address row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/jt_gray" android:contentDescription="Address"/>
                    <TextView
                        android:id="@+id/map_branch_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="  Hi-way Tabok Mandaue"
                        android:textColor="@color/jt_black"
                        android:textSize="13sp"/>
                    <ImageButton
                        android:id="@+id/map_btn_navigate"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_red"
                        android:src="@android:drawable/ic_menu_directions"
                        app:tint="@android:color/white"
                        android:contentDescription="Navigate"
                        android:padding="10dp"/>
                </LinearLayout>

                <!-- Phone row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@color/jt_gray" android:contentDescription="Phone"/>
                    <TextView
                        android:id="@+id/map_branch_phone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="  Phone/Landline Number: 9421872457"
                        android:textColor="@color/jt_black"
                        android:textSize="13sp"/>
                    <ImageButton
                        android:id="@+id/map_btn_call"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_red"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="@android:color/white"
                        android:contentDescription="Call"
                        android:padding="10dp"/>
                </LinearLayout>

                <!-- Disclaimer -->
                <TextView
                    android:id="@+id/map_branch_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="J&amp;T Home only accepts regular walk-in customers and does not accept packages from J&amp;T VIPs and E-Commerce Platforms (e.g. Shopee, Lazada, TikTok, etc.)"
                    android:textColor="@color/jt_gray"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</FrameLayout>