<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/jt_black"
            android:layout_marginBottom="16dp" />

        <!-- Base Rate Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Base Rate per KG (₱)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/jt_black"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_base_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. 50.0"
                    android:inputType="numberDecimal"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_rate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Save Rate"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/jt_red"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Broadcast Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Broadcast Message"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/jt_black"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/et_broadcast_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter message to broadcast..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_broadcast"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Send Broadcast"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/jt_red"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_admin_logout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Log Out"
            android:textColor="@color/jt_red"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/jt_red"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

</ScrollView>