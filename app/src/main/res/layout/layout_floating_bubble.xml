<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_floating_bubble.xml
    Place in: res/layout/
    This is the draggable bubble that floats over all screens.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bubble_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <!--
        Outer glow ring — gives a subtle pulse shadow effect
        Uses a semi-transparent red circle as background
    -->
    <FrameLayout
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_gravity="center"
        android:background="@drawable/bubble_glow_bg"
        android:alpha="0.35"/>

    <!--
        Main bubble — the solid red draggable circle
    -->
    <androidx.cardview.widget.CardView
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        app:cardCornerRadius="30dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/jt_red">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- AI label text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="AI"
                android:textColor="@color/jt_white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!--
        Small green "online" dot badge — bottom right of bubble
    -->
    <View
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/dot_green"/>

</FrameLayout>